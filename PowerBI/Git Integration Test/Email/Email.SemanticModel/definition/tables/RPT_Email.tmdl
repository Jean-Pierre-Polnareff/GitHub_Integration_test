		lineageTag: 586a9a29-59d7-4914-9fb0-f3cf39e399c3

	measure 'Pay Rate' = DIVIDE(CALCULATE(SUM(RPT_Email[payers])),CALCULATE(SUM(RPT_Email[delivered])))
