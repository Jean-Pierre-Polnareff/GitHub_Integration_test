	measure 'Email DateRange' = ```
			
			VAR RangeStart = Min(RPT_Email[send_date]) 
			VAR RangeEnd = Max(RPT_Email[send_date]) 
			Return
			CONCATENATE(CONCATENATE(format(RangeStart,"MMM-YY")," - "),format(RangeEnd,"MMM-YY"))
			```
		isHidden
