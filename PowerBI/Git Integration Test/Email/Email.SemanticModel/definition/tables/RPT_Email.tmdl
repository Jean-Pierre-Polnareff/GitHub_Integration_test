table RPT_Email
	lineageTag: 642589f0-d9b1-4e42-b2b0-8ec7aa47af06

	measure 'Bounce Rate' = DIVIDE(CALCULATE(SUM(RPT_Email[bounced])),CALCULATE(SUM(RPT_Email[sent])))
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 6b9d877a-274e-4803-84ad-e5f70852da18

	measure 'Delivered Rate' = DIVIDE(CALCULATE(SUM(RPT_Email[delivered])),CALCULATE(SUM(RPT_Email[sent])))
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 77bfd0c6-89dd-45a9-9073-258bdbdae7fd

	measure 'Open Rate' = DIVIDE(CALCULATE(SUM(RPT_Email[unq_opens])),CALCULATE(SUM(RPT_Email[delivered])))
