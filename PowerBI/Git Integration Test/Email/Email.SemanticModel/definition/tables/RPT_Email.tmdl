		lineageTag: 7e73cbe3-62e6-4953-b21a-d73e8d47d73a

	measure '$ per Delivered' = DIVIDE(CALCULATE(SUM(RPT_Email[payments])),CALCULATE(SUM(RPT_Email[delivered])))
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: c29bd086-78ce-456b-a200-b8bbd651658b

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Scrub Rate' =
			
			VAR invalidemailscrubbed = Calculate(sum(RPT_Email[invalid_email_scrubbed]))
			VAR optoutscrubbed = CALCULATE(SUM(RPT_Email[optout_scrubbed]))
			VAR whitelistscrubbed = CALCULATE(SUM(RPT_Email[whitelist_scrubbed]))
			VAR requested = CALCULATE(SUM(RPT_Email[requested]))
			RETURN
			CALCULATE((invalidemailscrubbed + optoutscrubbed + whitelistscrubbed)/requested)
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: b047fa11-260c-4aec-955b-ede75d6faa97

	measure TopN+Others =
			
			VAR ClientbySent = RANKX(ALL(RPT_Email[client]),calculate(SUM(RPT_Email[sent])),,DESC,Dense)
			RETURN
			IF(ClientbySent <= 'Select Top N Clients'[Select Top N Clients Value] , calculate(SUM(RPT_Email[sent])), BLANK())
		formatString: 0
		isHidden
		lineageTag: ad5d519c-e9a7-4c75-9c9c-308b8b8580d5

	measure 'Top10+Other by Letter' =
			VAR LettersbySent = RANKX(ALL(RPT_Email[LTR]),calculate(SUM(RPT_Email[sent])),,DESC,Dense)
			RETURN
