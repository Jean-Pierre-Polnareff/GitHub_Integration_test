	partition Rpt_Email_Spampage = m
		mode: import
		source =
				let
				    Source = Sql.Database("DFW2-BISQL-001", "CLIENT_ANALYTICS", [Query="SELECT [GUID]#(lf)      ,[LTR] AS [Letter]#(lf)      ,[DNA]#(lf)      ,[FileNumber] AS [CustomerID]#(lf)      ,[SourceSystem]  AS [CRM]#(lf)      ,[DomainName] AS [Send Domain]#(lf)      ,[Spam_date] AS [Spam Date]#(lf)      ,[Delivered_date] AS [Delivered Date]#(lf)      ,[ClientStream]#(lf)      ,[InitialBalance]#(lf)      ,[CurrentBalance]#(lf)      ,[CustomerState]#(lf)      ,[Spam_Count] AS [Spam Count]#(lf)      ,[Spam_Year] AS [Spam Year]#(lf)      ,[Spam_Quarter] AS [Spam Quarter]#(lf)      ,[MonthEnd]#(lf)      ,[Report_Date] AS [Report Date]#(lf)      ,[ClientId]#(lf)      ,[ClientParent]#(lf)      ,[asCrWeekV] AS [Current Week]#(lf)      ,FORMAT([ReportWeek],'yy-MM-dd') [Report Week]#(lf)#(tab)  ,CASE WHEN MONTH([Spam_date])=1 THEN 'Jan'#(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=2 THEN 'Feb' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=3 THEN 'Mar' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=4 THEN 'Apr' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=5 THEN 'May' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=6 THEN 'Jun' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=7 THEN 'Jul' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=8 THEN 'Aug' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=9 THEN 'Sep' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=10 THEN 'Oct' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=11 THEN 'Nov' #(lf)#(tab)#(tab)#(tab)WHEN MONTH([Spam_date])=12 THEN 'Dec' #(lf)#(tab)#(tab)#(tab)END AS [Spam Month]#(lf)     ,[ClientStreamId]#(lf)     ,[OfficeID]#(lf)#(lf)  FROM [dbo].[Rpt_Email_Spampage] (NOLOCK)#(lf)"])
				in
				    Source

	changedProperty = IsHidden

