table 'Neustar Summarized data'
	lineageTag: a47b4047-88b4-4905-9ed4-5620ef0cba15

	measure Intensity = CALCULATE(DIVIDE(SUM('Neustar Summarized data'[Cnt_Attempt]), SUM('Neustar Summarized data'[Score_phone])))
		formatString: 0.00
		lineageTag: 6ce98fd0-d83f-41bc-afb8-6fdaec8a3f72

	measure 'RPC % per unique dialed' = CALCULATE(DIVIDE(SUM('Neustar Summarized data'[Unq_RPC]), SUM('Neustar Summarized data'[Score_phone])))
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: c0c052d0-2829-440e-8276-ead87e6cef21

	measure 'WPC % per unique dialed' = CALCULATE(DIVIDE(SUM('Neustar Summarized data'[Unq_WPC]), SUM('Neustar Summarized data'[Score_phone])))
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 8bee761c-a253-42a4-8082-ecd6be9dfbfd

	measure 'RPC % per Attempt' = CALCULATE(DIVIDE(SUM('Neustar Summarized data'[total_RPC]), SUM('Neustar Summarized data'[Cnt_Attempt])))
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 18b894ae-5e03-4382-80b4-5fc9a3937fc3

	measure 'WPC % per Attempt' = CALCULATE(DIVIDE(SUM('Neustar Summarized data'[total_WPC]), SUM('Neustar Summarized data'[Cnt_Attempt])))
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: c2e02198-bd6b-4e74-9ec8-e9bbd3bbf2b6

	measure 'Percentile for RPC % per unique dialed' =
			
			Calculate(PERCENTILEX.EXC('Neustar Summarized data',[RPC % per unique dialed],0.5)
			----,ALL(Recovery[neustar_score])
			)
		lineageTag: f69d517b-e404-4ee8-ac54-b7af6586925a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Percentile for WPC % per Unique Dialed' = Calculate(PERCENTILEx.EXC('Neustar Summarized data',[WPC % per unique dialed],0.5))
		lineageTag: 58d2ff68-cb45-41ea-a83b-3e70d0928727

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '50th Percentile in RPC% per unique dialed' =
			
			VAR temptable =  SUMMARIZE('Neustar Summarized data',[phoneactivity],[neustar_score],"RPCU",[RPC % per unique dialed])
			RETURN
			PERCENTILEX.EXC(temptable,[RPCU],0.25)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 108ada5a-be30-4344-a9a5-71cdb4315ab5

	measure 'Cond Formatting RPC% per unique dialed' =
			
			VAR temptable =  SUMMARIZE('Neustar Summarized data',[phoneactivity],[neustar_score],"RPCU",[RPC % per unique dialed])
			RETURN
			 ---1st Quartile --->
			 IF([RPC % per unique dialed] <= VALUE(PERCENTILEX.INC(temptable,[RPCU],0.25)),1,
			 ---2nd Quartile -->
			 IF([RPC % per unique dialed] <= VALUE(PERCENTILEX.INC(temptable,[RPCU],0.5)),2,
			 ---3rd Quartile -->
			 IF([RPC % per unique dialed] <= VALUE(PERCENTILEX.INC(temptable,[RPCU],0.75)),3,
			 ---4th Quartile -->
			 IF([RPC % per unique dialed] > VALUE(PERCENTILEX.INC(temptable,[RPCU],0.75)),4))))
		lineageTag: 4a5855f9-039c-4d5d-89c9-807800f3624c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Measure =
			
			VAR temptable =  SUMMARIZE('Neustar Summarized data',[phoneactivity],[Neustar_score],"RPCU",[RPC % per unique dialed])
			VAR temptable2 =  CALCULATE(PERCENTILEX.INC(SUMMARIZE('Neustar Summarized data',[phoneactivity],[Neustar_score],"RPCU",[RPC % per unique dialed]),[RPCU],0.5))
			RETURN
			---IF(CALCULATE([RPC % per unique dialed]) <  value(temptable2) , 1,0)
			VALUE(temptable2)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 4fbac47c-6cf8-4e42-8029-186f2a8be997

	measure '75th Percentile RPC %' =
			
			CALCULATE(
				PERCENTILEX.INC('Neustar Summarized data',[RPC % per unique dialed],0.5)
			---,
			---ALLSELECTED('Recovery'[neustar_score]),
			---ALLSELECTED('Recovery'[Sort Order of Neustar Score])
			 ---,
			---ALL('Recovery'[neustar_score],
			---'Recovery'[Sort Order of Neustar Score])
			---,
			---ALLSELECTED('Recovery'[neustar_score]),
			---ALLSELECTED('Recovery'[Sort Order of Neustar Score])
			---ALL(
			---'Recovery'[phoneactivity],
			---'Recovery'[Sort Order of phoneactivity])
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: a1b90f6e-8c95-4321-b81f-34d3e411009f

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "TotalForSelectedCategory"
				}

	measure 'Selected Date Range' = SELECTEDVALUE('Neustar Summarized data'[Date Range], "All Date Ranges are selected.. Please select only one Date Range.")
		lineageTag: cf9fc793-448b-44a9-ae89-7b39f8564142

		annotation PBI_FormatHint = {"isText":true}

	measure 'Selected Segment' =
			
			IF( COUNTROWS(DISTINCT(ALL('Neustar Summarized data'[Segment]))) = COUNTROWS(DISTINCT(ALLSELECTED('Neustar Summarized data'[Segment]))) ,"All Segments(AXP Legal, Recover, RLK Series)",[List of Segment values])
			--- SELECTEDVALUE('Neustar Summarized data'[Segment], "Multiple Segments are selected.. Please select only one Segment at a time")
		lineageTag: 71f21bce-de1c-45b6-8ebc-80fe93ff42ec

		annotation PBI_FormatHint = {"isText":true}

	measure 'List of Segment values' =
			
			VAR __DISTINCT_VALUES_COUNT = DISTINCTCOUNT('Neustar Summarized data'[Segment])
			VAR __MAX_VALUES_TO_SHOW = 5
			RETURN
				IF(
					__DISTINCT_VALUES_COUNT > __MAX_VALUES_TO_SHOW,
					CONCATENATE(
						CONCATENATEX(
							TOPN(
								__MAX_VALUES_TO_SHOW,
								VALUES('Neustar Summarized data'[Segment]),
								'Neustar Summarized data'[Segment],
								ASC
							),
							'Neustar Summarized data'[Segment],
							", ",
							'Neustar Summarized data'[Segment],
							ASC
						),
						", etc."
					),
					CONCATENATEX(
						VALUES('Neustar Summarized data'[Segment]),
						'Neustar Summarized data'[Segment],
						", ",
						'Neustar Summarized data'[Segment],
						ASC
					)
				)
		lineageTag: efe02467-7738-4c3a-bc59-5b71879366b2

		annotation PBI_FormatHint = {"isText":true}

	measure 'Selected Date Range Gauge' = IF( [Selected Date Range] = "All Date Ranges are selected.. Please select only one Date Range.",  "#F8696B", "#63BE7B")
		lineageTag: 1fad5a77-d6bd-4870-81e9-742ad8b50f06

		annotation PBI_FormatHint = {"isText":true}

