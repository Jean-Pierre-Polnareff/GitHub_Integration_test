	column 'neustar_score (groups)' =
			SWITCH(
			  TRUE,
			  ISBLANK('Neustar Summarized data'[neustar_score]),
			  "(Blank)",
			  'Neustar Summarized data'[neustar_score] IN {"0",
			    "1",
			    "2"},
			  "0-2",
			  'Neustar Summarized data'[neustar_score] IN {"3",
			    "5"},
			  "3-5",
			  'Neustar Summarized data'[neustar_score] IN {"10",
			    "6",
			    "7"},
			  "6+",
			  'Neustar Summarized data'[neustar_score] IN {"Control"},
			  "Control",
			  'Neustar Summarized data'[neustar_score]
			)
		lineageTag: e7ff80c8-e1bf-4491-ac4d-3ef5d38e5313
		summarizeBy: none

